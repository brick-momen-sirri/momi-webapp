# Backend
PORT=3333
HOST=127.0.0.1

# Production generation backend. Use local_comfy only for local development.
GENERATION_BACKEND=runpod

# RunPod serverless ComfyUI worker. Do not commit real values.
RUNPOD_ENDPOINT_ID=your-runpod-endpoint-id
RUNPOD_API_KEY=your-runpod-api-key
# Required for dispatcher/api split so the acknowledged job ID is persisted
# immediately and can be resumed after dispatcher failover. Monolith defaults
# to the legacy synchronous endpoint when this is omitted.
RUNPOD_SUBMISSION_MODE=async
COMFY_ORG_API_KEY=your-comfy-org-api-key
RUNPOD_POLL_INTERVAL_MS=5000
RUNPOD_TIMEOUT_MS=2400000
RUNPOD_MAX_CONCURRENT_JOBS=10
# Logs RunPod endpoint URLs, status codes, job ids, and sanitized request bodies.
RUNPOD_DEBUG=false
JSON_BODY_LIMIT=15mb
MEDIA_UPLOAD_MAX_BYTES=1073741824
RUNPOD_OUTPUT_MAX_BYTES=1073741824
# Maximum size for downloaded RunPod text artifacts (prompts, captions). Default 1MiB.
# RUNPOD_TEXT_OUTPUT_MAX_BYTES=1048576
# How often to retry saving completed results that are still remote-only
# (their local persist failed). Default 10 minutes; set 0 to disable.
# RESULT_RECOVERY_INTERVAL_MS=600000
# Job persistence store. "json" (default) uses data/jobs.json; "sqlite" uses a
# SQLite DB (jobs and archived items are migrated from their .json files on
# first boot). Experimental.
# JOB_STORE_DRIVER=json
# JOBS_SQLITE_PATH=./data/jobs.sqlite
# JOBS_ARCHIVED_SQLITE_PATH=./data/archived-items.sqlite
# Process ownership for the web/worker split. Keep monolith until the topology
# flip; dispatcher/api roles require SQLite row-level writes.
# ROLE=monolith
# JOBS_ROW_LEVEL_WRITES=false
# PM2 rollout flags: migrate shared SQLite state under the monolith first, keep
# it enabled for topology rollback, then explicitly enable dispatcher:1 + api:N.
# MOMI_SHARED_STATE=false
# MOMI_TOPOLOGY_SPLIT=false
# MOMI_API_INSTANCES=2
# MOMI_DISPATCHER_PORT=3334
# Shared users/sessions/projects store plus derived media index. Required before
# ROLE=api/dispatcher; migrates JSON stores once and leaves them frozen.
# APP_STATE_DRIVER=json
# APP_STATE_SQLITE_PATH=./data/app-state.sqlite
# Stage D dispatcher coordination defaults. The dispatcher polls for API-created
# jobs, heartbeats its crash-safe SQLite lease, and checkpoints WAL passively.
# DISPATCHER_POLL_INTERVAL_MS=350
# DISPATCHER_LEASE_TTL_MS=15000
# DISPATCHER_LEASE_HEARTBEAT_MS=5000
# DISPATCHER_WAL_CHECKPOINT_MS=30000
# Observability: /metrics (Prometheus text) is always served on every role. The
# dispatch/queue watchdog logs [alert] lines on state transitions (dispatcher
# judges queue stalls; the lowest-id API worker watches for a dead dispatcher
# lease) and optionally POSTs each alert to a webhook. Empty URL = logs only.
# WATCHDOG_INTERVAL_MS=30000
# WATCHDOG_QUEUE_STALL_EVALS=4
# WATCHDOG_DISK_FREE_MIN_BYTES=5368709120
# WATCHDOG_MEMORY_HIGH_MIB=1275
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# ALERT_WEBHOOK_FORMAT=slack
# SQLite disaster recovery: consistent hot snapshots (integrity-checked,
# rotated) of jobs/archived-items/app-state, taken via the SQLite online backup
# API so WAL-resident rows are never lost. Runs on the dispatcher/monolith only.
# This host has a single local volume, so BACKUP_AZURE_SAS_URL (a container SAS
# URL with write access) is what makes this real DR rather than a local-only
# safety net. Never commit the SAS URL; set it in the process environment.
# SQLITE_BACKUP_ENABLED=false
# SQLITE_BACKUP_INTERVAL_MS=3600000
# SQLITE_BACKUP_RETENTION_COUNT=48
# SQLITE_BACKUP_STAGING_DIR=./data/backups
# BACKUP_AZURE_SAS_URL=https://<account>.blob.core.windows.net/<container>?<sas>
# BACKUP_AZURE_PREFIX=momi-backend
# AZCOPY_PATH=azcopy
# Fallback for local/dev RunPod use without RUNPOD_INPUT_BASE_URL:
# oversized image inputs are resized/re-encoded before inline JSON submission.
RUNPOD_INLINE_IMAGE_AUTO_COMPRESS=true
RUNPOD_INLINE_IMAGE_MAX_DIMENSION=4096
RUNPOD_INLINE_IMAGE_MIN_QUALITY=55
MEDIA_SCAN_CACHE_MS=60000
# Dispatcher refresh cadence for the shared existing-media index.
# MEDIA_INDEX_REFRESH_MS=500
MEMORY_LOG_INTERVAL_MS=15000
# Public HTTPS URL for this backend, used to send RunPod original-quality media
# as signed download links instead of oversized base64 JSON bodies.
# Examples: https://api.yourdomain.com or a Cloudflare/ngrok tunnel.
# RUNPOD_INPUT_BASE_URL=https://your-public-backend.example.com
# RUNPOD_INPUT_URL_SECRET=optional-separate-signing-secret

# Optional comma-separated emails that can sign in for viewing only.
# Built-in demo identifiers also include demo@brickvisual.com and momi.demo@brickvisual.com.
# MOMI_DEMO_EMAILS=client.demo@brickvisual.com

# Serverless-compatible Comfy workflow JSON files.
SERVERLESS_WORKFLOW_ROOT=C:\Momi-Animation\workflow
# Optional override for all workflow roots, separated with semicolons on Windows.
# WORKFLOW_ROOTS=C:\Momi-Animation\workflow

# Optional text/image prompt helper endpoint. This must be a text-returning worker,
# not the serverless Comfy generation worker above.
# PROMPT_RUNPOD_ENDPOINT_ID=your-text-helper-runpod-endpoint-id
# PROMPT_RUNPOD_API_KEY=your-text-helper-runpod-api-key

# Optional Seedance prompt-generation workflow overrides. By default this runs
# workflow/prompt_generation/Seedance_prompt_generation.json on the main Comfy RunPod worker.
# SEEDANCE_PROMPT_WORKFLOW_PATH=C:\Momi-Animation\workflow\prompt_generation\Seedance_prompt_generation.json
# SEEDANCE_PROMPT_OPENAI_MODEL=gpt5.5-pro

# Optional Kling image-to-video prompt-generation workflow overrides. By default this runs
# workflow/prompt_generation/Kling_image_to_video_prompt_generation.json on the main Comfy RunPod worker.
# KLING_PROMPT_WORKFLOW_PATH=C:\Momi-Animation\workflow\prompt_generation\Kling_image_to_video_prompt_generation.json
# KLING_PROMPT_SKILL_PATH=C:\Momi-Animation\workflow\prompt_generation\Kling_image_to_video_skill.md
# KLING_PROMPT_OPENAI_MODEL=gpt5.5-pro

# Optional local ComfyUI development settings.
# GENERATION_BACKEND=local_comfy
# COMFY_SERVERS=http://127.0.0.1:8201,http://127.0.0.1:8202
# COMFY_ROOT=C:\ComfyUI_windows_portable_nvidia_cu128\ComfyUI_windows_portable\ComfyUI
# COMFY_POOL_ROOT=C:\Comfy_pool

# Optional Credit Tracker sync target for serverless jobs.
# Defaults to the main local ComfyUI dashboard at http://127.0.0.1:8188, then falls back to COMFY_SERVERS.
# CREDIT_TRACKER_URLS=http://127.0.0.1:8188
# CREDIT_TRACKER_SYNC_TOKEN=optional-shared-token
# Off by default because shared Comfy/company balances can move from other users or parallel jobs.
# Enable only when this app is the only process spending the configured company credits.
# CREDIT_BALANCE_DELTA_ACCOUNTING=exclusive

# Frontend, only needed when the API is not served through the Vite /api proxy.
# VITE_API_BASE_URL=http://127.0.0.1:3333
