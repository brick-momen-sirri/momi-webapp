# Backend
PORT=3333
HOST=127.0.0.1

# Production generation backend. Use local_comfy only for local development.
GENERATION_BACKEND=runpod

# RunPod serverless ComfyUI worker. Do not commit real values.
RUNPOD_ENDPOINT_ID=your-runpod-endpoint-id
RUNPOD_API_KEY=your-runpod-api-key
COMFY_ORG_API_KEY=your-comfy-org-api-key
RUNPOD_POLL_INTERVAL_MS=5000
RUNPOD_TIMEOUT_MS=900000
RUNPOD_MAX_CONCURRENT_JOBS=10
# Public HTTPS URL for this backend, used to send RunPod original-quality media
# as signed download links instead of oversized base64 JSON bodies.
# Examples: https://api.yourdomain.com or a Cloudflare/ngrok tunnel.
# RUNPOD_INPUT_BASE_URL=https://your-public-backend.example.com
# RUNPOD_INPUT_URL_SECRET=optional-separate-signing-secret

# Optional comma-separated emails that can sign in for viewing only.
# Built-in demo identifiers also include demo@brickvisual.com and momi.demo@brickvisual.com.
# MOMI_DEMO_EMAILS=client.demo@brickvisual.com

# Serverless-compatible Comfy workflow JSON files.
SERVERLESS_WORKFLOW_ROOT=C:\Momi-Animation\workflow
# Optional override for all workflow roots, separated with semicolons on Windows.
# WORKFLOW_ROOTS=C:\Momi-Animation\workflow

# Optional text/image prompt helper endpoint. This must be a text-returning worker,
# not the serverless Comfy generation worker above.
# PROMPT_RUNPOD_ENDPOINT_ID=your-text-helper-runpod-endpoint-id
# PROMPT_RUNPOD_API_KEY=your-text-helper-runpod-api-key

# Optional local ComfyUI development settings.
# GENERATION_BACKEND=local_comfy
# COMFY_SERVERS=http://127.0.0.1:8201,http://127.0.0.1:8202
# COMFY_ROOT=C:\ComfyUI_windows_portable_nvidia_cu128\ComfyUI_windows_portable\ComfyUI
# COMFY_POOL_ROOT=C:\Comfy_pool

# Optional Credit Tracker sync target for serverless jobs.
# Defaults to the main local ComfyUI dashboard at http://127.0.0.1:8188, then falls back to COMFY_SERVERS.
# CREDIT_TRACKER_URLS=http://127.0.0.1:8188
# CREDIT_TRACKER_SYNC_TOKEN=optional-shared-token

# Frontend, only needed when the API is not served through the Vite /api proxy.
# VITE_API_BASE_URL=http://127.0.0.1:3333
